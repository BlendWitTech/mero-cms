# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Theme zip exports
themes/*.zip

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Runtime state — written by the wizard or auto-generated at boot.
# These contain DATABASE_URL (with passwords), JWT_SECRET, license
# keys, and other sensitive values. Never commit. The MERO_DATA_DIR
# pattern (set by Docker Compose) keeps these out of the source tree
# entirely on hosted installs; this is the belt-and-braces line for
# local dev where they default back to backend/.
secrets.json
setup.json
backend/secrets.json
backend/setup.json
backend/data/

# Captured response cache from public.controller — generated by the
# build pipeline for some debug paths; not source-of-truth and should
# never be committed.
backend/site-data.json

# Generated theme widget registries (built from theme.json)
themes/*/src/widget-registry.generated.ts

# Bundle build outputs (download endpoint generates these into a
# temp dir; if anyone runs it locally and pipes to disk, keep it
# out of git).
release-bundles/

# OS / Editor
.DS_Store
.idea/
.vscode/
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/

# Claude Code memory
.claude/

# Media uploads (user-generated content)
backend/uploads/

# Temp / packaging directories
temp_theme/
temp_website_repo/
tmp/

# Prisma generated client (regenerated on build)
backend/node_modules/.prisma/

# Theme build artifacts
themes/*/node_modules/
themes/*/.next/
themes/*/out/

# Blendwit internal license signing keys — NEVER commit
tools/keys/
