{
  "name": "mero-cms",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "themes/marketing-theme"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:theme": "node scripts/dev-theme.js",
    "dev:db": "docker compose up db -d",
    "dev": "concurrently --restart-tries 5 --restart-after 1500 \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:theme\"",
    "dev:all": "docker compose up db -d && concurrently --restart-tries 5 --restart-after 1500 \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:theme\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "install:all": "npm install",
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup.ps1",
    "reset": "powershell -ExecutionPolicy Bypass -File ./scripts/reset.ps1",
    "db:init": "npx prisma migrate dev -w backend",
    "db:migrate": "npx prisma migrate dev -w backend",
    "db:push": "npx prisma db push -w backend",
    "db:seed": "npm run seed -w backend",
    "start": "node ./scripts/start.js",
    "start:prod": "node backend/dist/main",
    "package-theme": "node scripts/package-theme.js",
    "zip-theme": "node scripts/zip-theme.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^7.7.0"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0"
  }
}