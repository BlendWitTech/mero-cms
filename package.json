{
  "name": "blendwit-base-cms",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "demo"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:demo": "npm run dev -w demo",
    "dev:theme": "node scripts/dev-theme.js",
    "dev:db": "docker compose up db -d",
    "dev": "concurrently --restart-tries 5 --restart-after 1500 \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:theme\"",
    "dev:all": "concurrently --restart-tries 5 --restart-after 1500 \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:theme\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "install:all": "npm install",
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup.ps1",
    "reset": "powershell -ExecutionPolicy Bypass -File ./scripts/reset.ps1",
    "db:init": "npx prisma migrate dev -w backend",
    "db:migrate": "npx prisma migrate dev -w backend",
    "db:push": "npx prisma db push -w backend",
    "db:seed": "npm run seed -w backend",
    "start": "node ./scripts/start.js",
    "start:prod": "node backend/dist/main",
    "package-theme": "node scripts/package-theme.js",
    "zip-theme": "node scripts/zip-theme.js"
  },
  "overrides": {
    "@tiptap/core": "3.18.0",
    "@tiptap/extension-blockquote": "3.18.0",
    "@tiptap/extension-bold": "3.18.0",
    "@tiptap/extension-bubble-menu": "3.18.0",
    "@tiptap/extension-bullet-list": "3.18.0",
    "@tiptap/extension-code": "3.18.0",
    "@tiptap/extension-code-block": "3.18.0",
    "@tiptap/extension-code-block-lowlight": "3.18.0",
    "@tiptap/extension-document": "3.18.0",
    "@tiptap/extension-dropcursor": "3.18.0",
    "@tiptap/extension-floating-menu": "3.18.0",
    "@tiptap/extension-font-family": "3.18.0",
    "@tiptap/extension-gapcursor": "3.18.0",
    "@tiptap/extension-hard-break": "3.18.0",
    "@tiptap/extension-heading": "3.18.0",
    "@tiptap/extension-highlight": "3.18.0",
    "@tiptap/extension-horizontal-rule": "3.18.0",
    "@tiptap/extension-image": "3.18.0",
    "@tiptap/extension-italic": "3.18.0",
    "@tiptap/extension-link": "3.18.0",
    "@tiptap/extension-list": "3.18.0",
    "@tiptap/extension-list-item": "3.18.0",
    "@tiptap/extension-list-keymap": "3.18.0",
    "@tiptap/extension-ordered-list": "3.18.0",
    "@tiptap/extension-paragraph": "3.18.0",
    "@tiptap/extension-placeholder": "3.18.0",
    "@tiptap/extension-strike": "3.18.0",
    "@tiptap/extension-subscript": "3.18.0",
    "@tiptap/extension-superscript": "3.18.0",
    "@tiptap/extension-task-item": "3.18.0",
    "@tiptap/extension-task-list": "3.18.0",
    "@tiptap/extension-text": "3.18.0",
    "@tiptap/extension-text-align": "3.18.0",
    "@tiptap/extension-text-style": "3.18.0",
    "@tiptap/extension-typography": "3.18.0",
    "@tiptap/extension-underline": "3.18.0",
    "@tiptap/extensions": "3.18.0",
    "@tiptap/pm": "3.18.0",
    "@tiptap/react": "3.18.0",
    "@tiptap/starter-kit": "3.18.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^6.19.2"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
