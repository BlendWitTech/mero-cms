# ── Mero CMS Demo Playground ─────────────────────────────────────────────────
# Copy to .env.local and fill in values.

# NextAuth
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars   # openssl rand -base64 32

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3003/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3003/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LinkedIn OAuth
# Create at: https://www.linkedin.com/developers/apps
# Authorised redirect URL: http://localhost:3003/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Mero CMS backend — leads are submitted here
CMS_API_URL=http://localhost:3001

# URL of your live demo CMS (the actual CMS instance visitors can explore)
# Leave blank to hide the "Launch Demo CMS" button
NEXT_PUBLIC_DEMO_CMS_URL=https://demo-cms.blendwit.com

# Pricing page — links to your purchase/contact pages
NEXT_PUBLIC_BUY_URL=https://blendwit.com/mero-cms/pricing
NEXT_PUBLIC_CONTACT_URL=https://blendwit.com/contact
