model TeamMember {
  id          String   @id @default(uuid())
  name        String
  role        String
  bio         String?  @db.Text
  image       String?
  socialLinks Json?
  order       Int      @default(0)
  theme       String?
  attributes  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
