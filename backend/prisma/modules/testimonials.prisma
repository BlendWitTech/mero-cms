model Testimonial {
  id            String   @id @default(uuid())
  clientName    String
  clientRole    String?
  clientCompany String?
  clientAvatar  String?
  content       String
  rating        Int?     @default(5)
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
