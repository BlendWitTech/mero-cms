model Page {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  content       String?
  data          Json?
  description   String?
  featuredImage String?
  status        String   @default("DRAFT")
  settings      Json?
  theme         String?
  // Scheduled publish time. When status='SCHEDULED' and publishAt <= now,
  // the content-scheduler cron flips status to 'PUBLISHED'.
  publishAt     DateTime?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
