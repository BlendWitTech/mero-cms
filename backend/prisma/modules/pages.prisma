model Page {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  content       String?
  data          Json?
  description   String?
  featuredImage String?
  status        String   @default("DRAFT")
  settings      Json?
  theme         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
