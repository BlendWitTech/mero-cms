// Land plot listings — dedicated module for real-estate plot themes
// Separate from the Project model which is for construction/portfolio themes

model Plot {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String        @db.Text
  content     String?       @db.Text
  coverImage  String?
  gallery     String[]
  status      String        @default("available")
  categoryId  String?
  category    PlotCategory? @relation(fields: [categoryId], references: [id])
  location    String?
  featured    Boolean       @default(false)
  priceFrom   String?
  priceTo     String?
  areaFrom    String?
  areaTo      String?
  facing      String?
  roadAccess  String?
  theme       String?
  attributes  Json?
  seo         Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PlotCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  theme       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plots       Plot[]
}
