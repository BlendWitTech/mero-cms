model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  password            String
  name                String?
  roleId              String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  forcePasswordChange Boolean       @default(false)
  ipWhitelist         String[]      @default([])
  twoFactorEnabled    Boolean       @default(false)
  twoFactorSecret     String?
  failedLoginAttempts Int           @default(0)
  lockoutUntil        DateTime?
  preferences         Json?
  avatar              String?
  bio                 String?
  status              String        @default("ACTIVE")
  isActive            Boolean       @default(true)
  lastActive          DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  activityLogs        ActivityLog[]
  comments            Comment[]
  posts               Post[]
  apiKeys             ApiKey[]
  refreshTokens       RefreshToken[]
  role                Role          @relation(fields: [roleId], references: [id])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  tokenHash  String    @unique
  prefix     String
  userId     String
  scopes     String[]  @default([])
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

// Refresh-token rotation. Each row is a single refresh token (stored as a
// SHA-256 hash so a DB leak doesn't hand over bearer credentials).
// `family` groups a login's rotated descendants together — if we ever see
// a token from a family that's already been rotated, the entire family
// is revoked on the theory that an attacker is replaying a stolen token.
model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  family     String    // UUID tying rotated descendants together
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?   // tokenHash of the successor after rotation
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@index([tokenHash])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  status    String   @default("INFO")
  user      User     @relation(fields: [userId], references: [id])
}

model Invitation {
  id          String   @id @default(uuid())
  email       String   @unique
  roleId      String
  ipWhitelist String[] @default([])
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  status      String   @default("PENDING")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions Json
  level       Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  icon        String?
  users       User[]
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id         String   @id @default(uuid())
  userId     String?
  type       String
  title      String
  message    String
  link       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  targetRole String?
}

model Media {
  id         String   @id @default(uuid())
  filename   String
  url        String
  mimetype   String
  size       Int
  createdAt  DateTime @default(now())
  altText    String?
  folder     String   @default("root")
  height     Int?
  metadata   Json?
  updatedAt  DateTime @updatedAt
  width      Int?
  // PUBLIC (default): statically served from /uploads — anyone with the URL
  // can fetch. PRIVATE: lives under /uploads/private/ and is only reachable
  // through a time-limited signed URL obtained from POST /media/:id/sign.
  visibility String   @default("PUBLIC")
  ownerId    String?
}

model Collection {
  id          String           @id @default(uuid())
  name        String           @unique
  slug        String           @unique
  description String?
  type        String           @default("COLLECTION")
  fields      Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(uuid())
  collectionId String
  data         Json
  slug         String?
  isPublished  Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model Form {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  fields      Json
  settings    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submissions FormSubmission[]
}

model FormSubmission {
  id        String   @id @default(uuid())
  formId    String
  data      Json
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  events    String[]
  secret    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Package {
  id            String   @id
  name          String
  websiteType   String
  tier          Int
  aiEnabled     Boolean  @default(false)
  priceMin      Int?
  priceMax      Int?
  isCustomPrice Boolean  @default(false)
  tagline       String
  features      String[]
  comingSoon    String[] @default([])
  starterThemes String[] @default([])
  supportLevel  String
  highlighted   Boolean  @default(false)
  // Enforcement metadata
  storageLimitGB Int      @default(5)
  teamLimit      Int      @default(1)
  hasWhiteLabel  Boolean  @default(false)
  hasApiAccess   Boolean  @default(false)
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// One row per attempted purchase. Created the moment a customer
/// initiates checkout and updated as the provider's webhook (or
/// return URL) reports the outcome. The license JWT signed for a
/// successful order is persisted on `licenseKey` so the success
/// page can show it without depending on email delivery.
///
/// Lives in _core.prisma because payments is a core module — the
/// Order table must exist whether or not the customer enabled the
/// optional content modules. Put here it survives the build-schema
/// reassembly that the setup wizard runs on module changes.
model Order {
  id              String    @id @default(cuid())
  customerEmail   String
  customerName    String?
  customerPhone   String?

  // What was purchased.
  itemType        String    // 'package' | 'plugin' | 'cloud-tier' | 'maintenance'
  packageId       String?
  pluginSlug      String?
  cloudTierId     String?

  // Money.
  amountNPR       Int
  currency        String    @default("NPR")
  amountCharged   Int?      // amount actually charged in `currency` (after FX)

  // Provider lifecycle.
  provider        String    // 'stripe' | 'khalti' | 'esewa'
  providerOrderId String?   @unique
  providerPayload Json?
  status          String    @default("pending")
  failureReason   String?

  // What we issued back.
  licenseKey       String?   @db.Text
  licenseExpiresAt DateTime?

  metadata        Json?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  paidAt          DateTime?

  @@index([customerEmail])
  @@index([provider, status])
  @@index([itemType, packageId])
}
