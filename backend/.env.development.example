# ── Development (local machine) ──────────────────────────────────────────────
# Copy to .env and fill in real values.
# This file is safe to commit. Never commit .env with real secrets.

NODE_ENV=development
PORT=3001

# PostgreSQL — local Docker or Postgres.app
DATABASE_URL=postgresql://admin:password123@localhost:5432/mero_cms_dev

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-dev-jwt-secret-min-32-chars

# CORS — local frontend
CORS_ORIGINS=http://localhost:3000

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Setup wizard (auto-written after setup completes — leave empty on fresh install)
ENABLED_MODULES=
SETUP_COMPLETE=false

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL & STORAGE → Configure from Dashboard → Settings, not .env
# ─────────────────────────────────────────────────────────────────────────────
