# ── Development (local machine) ──────────────────────────────────────────────
# Copy to .env and fill in real values.
# This file is safe to commit. Never commit .env with real secrets.

NODE_ENV=development
PORT=3001

# PostgreSQL — local Docker or Postgres.app
DATABASE_URL=postgresql://admin:password123@localhost:5432/mero_cms

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-dev-jwt-secret-min-32-chars

# CORS — local frontend (admin on :3000, theme on :3002)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Themes directory — defaults to ../themes relative to cwd
# THEMES_DIR=../themes

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# App URL — used to resolve relative media URLs in emails (logo, etc.)
APP_URL=http://localhost:3001

# Theme cache clearing — URL of the running theme + shared secret
THEME_URL=http://localhost:3002
REVALIDATE_SECRET=your-revalidate-secret

# Analytics (optional in dev)
# ANALYTICS_ENABLED=false

# License — obtain from Blendwit or generate with: node tools/issue-license.js
LICENSE_KEY=
