# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (use Neon, Supabase, or Railway Postgres)
DATABASE_URL="postgresql://user:password@host:5432/mero_cms?schema=public"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: `openssl rand -base64 64`
JWT_SECRET="replace-with-a-strong-random-secret"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (admin UI + theme URLs)
FRONTEND_URL="https://your-admin.vercel.app"
CORS_ORIGINS="https://your-admin.vercel.app,https://your-theme.vercel.app"

# ── App URL ───────────────────────────────────────────────────────────────────
# Public URL of this backend — used in emails & self-referencing links
APP_URL="https://your-backend.up.railway.app"

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Setup wizard (auto-written — do not edit manually) ────────────────────────
# These are written automatically after the CMS setup wizard completes.
# Empty values here trigger the setup wizard on first boot.
ENABLED_MODULES=
SETUP_COMPLETE=false

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL, CLOUD STORAGE & THEME SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
# These are configured from the CMS Dashboard — NOT from .env:
#   Email (SMTP / Resend)  →  Dashboard → Settings → Email Services
#   Cloud Storage          →  Dashboard → Settings → Media / Storage
#     (Cloudinary or S3 / Cloudflare R2)
# ─────────────────────────────────────────────────────────────────────────────
