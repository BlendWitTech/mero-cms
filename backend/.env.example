# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (use Neon, Supabase, or Railway Postgres)
DATABASE_URL="postgresql://user:password@host:5432/blendwit_cms?schema=public"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: `openssl rand -base64 32`
JWT_SECRET="replace-with-a-strong-random-secret"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (admin UI + theme URLs)
FRONTEND_URL="https://your-admin.vercel.app"
CORS_ORIGINS="https://your-admin.vercel.app,https://your-theme.vercel.app"

# ── SMTP / Email ──────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="noreply@example.com"
SMTP_SECURE="false"

# ── Cloud Storage ─────────────────────────────────────────────────────────────
# Option 1: Cloudinary (recommended for images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Option 2: S3 / Cloudflare R2
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""

# ── Module Configuration ──────────────────────────────────────────────────────
# Set by the setup wizard after first run. Leave empty to trigger setup wizard.
ENABLED_MODULES=""
SETUP_COMPLETE="false"
