# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (use Neon, Supabase, or Railway Postgres)
DATABASE_URL="postgresql://user:password@host:5432/blendwit_cms?schema=public"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: `openssl rand -base64 32`
JWT_SECRET="replace-with-a-strong-random-secret"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Public URL where clients (and themes) reach this backend.
# In dev, leave blank and the backend falls back to http://localhost:${PORT}.
# In prod, set to the full URL — this is written into each theme's .env.local
# as CMS_API_URL / NEXT_PUBLIC_CMS_API_URL on theme setup + activation.
BACKEND_PUBLIC_URL=""

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (admin UI + theme URLs)
FRONTEND_URL="https://your-admin.vercel.app"
CORS_ORIGINS="https://your-admin.vercel.app,https://your-theme.vercel.app"

# ── SMTP / Email ──────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="noreply@example.com"
SMTP_SECURE="false"

# ── Cloud Storage ─────────────────────────────────────────────────────────────
# Option 1: Cloudinary (recommended for images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Option 2: S3 / Cloudflare R2
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""

# ── Module Configuration ──────────────────────────────────────────────────────
# Set by the setup wizard after first run. Leave empty to trigger setup wizard.
ENABLED_MODULES=""
SETUP_COMPLETE="false"

# ── Demo Mode ────────────────────────────────────────────────────────────────
# Set DEMO_MODE=true only on public demo deployments, never in production.
DEMO_MODE="false"
DEMO_ADMIN_EMAIL="admin@merocms.test"
DEMO_ADMIN_PASSWORD="change-this-demo-password"
DEMO_BRANCH="stable"
DEMO_INTERNAL_SECRET=""

# Public site URL (used for demo login redirect, OG tags, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── License / Tier ───────────────────────────────────────────────────────────
# Active license tier: basic | premium | enterprise | custom (default: premium)
# Controls which modules and themes are available.
TIER="premium"
