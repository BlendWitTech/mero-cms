# ── Staging (Railway) ────────────────────────────────────────────────────────
# Set these as environment variables in Railway dashboard.
# Do NOT commit real values. This file documents required variables only.

NODE_ENV=production
PORT=3001

# PostgreSQL — Railway Postgres plugin provides this automatically
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT
JWT_SECRET=your-staging-jwt-secret-min-64-chars

# CORS — Vercel preview/staging URL
CORS_ORIGINS=https://your-project.vercel.app
CORS_VERCEL_PROJECT=your-vercel-project-name

# File uploads (Railway ephemeral filesystem — use external storage in production)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# App URL (used in emails / self-referencing links)
APP_URL=https://your-backend.up.railway.app
