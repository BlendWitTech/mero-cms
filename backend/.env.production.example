# ── Production environment variables ──────────────────────────────────────
# Copy this to .env and fill in real values before deploying.
# On Railway, set these via the Variables tab — do NOT commit real secrets.

NODE_ENV=production
PORT=3001

# Railway provides this automatically when you add a Postgres service:
# ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET

# Webhook secret encryption key — encrypts outbound webhook signing secrets at rest.
# Required (min 16 chars). Rotating this key invalidates existing encrypted secrets,
# so customers will need to re-enter each webhook's secret after rotation.
# Generate with: openssl rand -base64 32
WEBHOOK_SECRET_KEY=CHANGE_ME_STRONG_RANDOM_WEBHOOK_KEY

# Comma-separated list of allowed origins (your Vercel URLs)
CORS_ORIGINS=https://your-cms.vercel.app,https://your-theme.vercel.app

THEMES_DIR=/themes
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Leave empty — setup wizard writes this on first run
ENABLED_MODULES=
SETUP_COMPLETE=false
