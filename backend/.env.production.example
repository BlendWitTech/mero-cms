# ── Production (Railway / custom domain) ─────────────────────────────────────
# Set these as environment variables in the Railway dashboard (production service).
# Do NOT commit real values.

NODE_ENV=production
PORT=3001

# PostgreSQL — Railway Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT — use a strong secret, different from staging
# Generate: openssl rand -base64 64
JWT_SECRET=your-production-jwt-secret-min-64-chars

# CORS — production frontend domain
CORS_ORIGINS=https://blendwit.com,https://www.blendwit.com

# App URL
APP_URL=https://api.blendwit.com

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Setup wizard (auto-written after setup completes — leave empty on fresh deploy)
ENABLED_MODULES=
SETUP_COMPLETE=false

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL & STORAGE → Configure from Dashboard → Settings, not .env
# ─────────────────────────────────────────────────────────────────────────────
