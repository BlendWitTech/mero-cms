# ── Production (Railway / custom domain) ─────────────────────────────────────
# Set these as environment variables in Railway dashboard (production service).
# Do NOT commit real values.

NODE_ENV=production
PORT=3001

# PostgreSQL — Railway Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT — use a strong secret, different from staging
JWT_SECRET=your-production-jwt-secret-min-64-chars

# CORS — production frontend domain
CORS_ORIGINS=https://blendwit.com,https://www.blendwit.com

# File uploads — consider switching to S3/Cloudflare R2 for production
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# App URL
APP_URL=https://api.blendwit.com
