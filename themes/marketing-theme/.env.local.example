# URL of the client's CMS backend (Railway deployment)
CMS_API_URL=https://your-backend.railway.app

# Public URL of this theme (Vercel deployment URL)
NEXT_PUBLIC_SITE_URL=https://your-theme.vercel.app

# Must match REVALIDATE_SECRET in the CMS backend env
# Used to secure the /api/revalidate endpoint
REVALIDATE_SECRET=change-me-to-a-random-string
