# Mero CMS backend URL (NestJS app on port 3001 in local dev).
# Theme uses this for all /public, /auth, /menus, /seo-meta, etc.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Hostname Next/Image is allowed to load remote media from (the
# backend serves uploads at /uploads/...). For local dev the host is
# the same machine; production deployments use the backend's domain.
NEXT_PUBLIC_MEDIA_HOST=localhost

# Optional: when running the theme inside the admin's iframe for the
# visual editor, the admin appends ?editMode=1 — the EditorBridge
# component reads that. No env var needed for normal operation.
