# ── Mero CMS — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in all required values before running.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=changeme
DB_NAME=mero_cms
# Full URL used by the backend (auto-constructed in docker-compose)
# DATABASE_URL=postgresql://admin:changeme@db:5432/mero_cms?schema=public

# ── Authentication ────────────────────────────────────────────────────────────
# Required — use a long random string (openssl rand -base64 32)
JWT_SECRET=replace-with-a-long-random-secret

# ── Licensing ─────────────────────────────────────────────────────────────────
# Obtain from Blendwit after purchase.
# Generate internally with: node tools/issue-license.js --tier Premium --domain yourdomain.com
LICENSE_KEY=

# ── Networking ────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000
# Comma-separated origins allowed by the backend CORS policy
CORS_ORIGINS=http://localhost:3000
# Public URL the frontend uses to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Organisation / Branding ───────────────────────────────────────────────────
# Used as a prefix for Docker container names
ORG_NAME=mero

# ── Module Selection (set automatically by setup wizard) ─────────────────────
SETUP_COMPLETE=false
ENABLED_MODULES=

# ── Mail (optional — required for invitations and password reset) ─────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM="Mero CMS <noreply@example.com>"

# ── Webhook Secret Encryption ─────────────────────────────────────────────────
# Defaults to JWT_SECRET if not set — set separately for extra isolation
WEBHOOK_SECRET_KEY=

# ── pgAdmin (optional — remove service from compose if not needed) ────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme
